---
import '../styles/themes.css';
import '../styles/global.css';
import NavBar from '../components/NavBar.astro';
import NavBarScript from '../components/NavBarScript.astro';
import ScrollLab from '../components/ScrollLab.jsx';
import { ClientRouter } from 'astro:transitions';

interface Props {
  theme: string;
  activeSlug: string;
  title?: string;
}

const { theme, activeSlug, title = 'Phone That Cares About You' } = Astro.props;
const showScrollLab = activeSlug !== 'welcome';
---

<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body data-theme={theme}>
    <NavBar activeSlug={activeSlug} />
    <main>
      <slot />
    </main>
    {showScrollLab && <ScrollLab client:load />}
    <NavBarScript />
    <style is:global>
      main {
        padding-top: clamp(2rem, 5vw, 4rem);
        padding-bottom: 6rem;
        /* On desktop, offset for the left nav */
        margin-left: 140px;
      }

      @media (max-width: 960px) {
        main {
          margin-left: 0;
          /* On mobile, clear the top nav bar */
          padding-top: calc(52px + clamp(1rem, 3.5vw, 2.25rem));
        }
      }
    </style>
  </body>
</html>
