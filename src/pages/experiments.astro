---
import BaseLayout from '../layouts/BaseLayout.astro';
import Carousel from '../components/Carousel.jsx';

const phoneOsSlides = [
  {
    src: '/phone-os/PTC1.png',
    caption: 'Lock Screen — a quiet radial control, with just the essentials at the edges.',
  },
  {
    src: '/phone-os/PTC5.png',
    caption: 'Home — the apps you actually use, nothing pretending to be a dashboard.',
  },
  {
    src: '/phone-os/PTC3.png',
    caption: 'Connect — one list for everyone, across every messaging platform.',
  },
  {
    src: '/phone-os/PTC3b.png',
    caption: 'Think Out Loud — a private space to work through what you want to say.',
  },
  {
    src: '/phone-os/PTC3c.png',
    caption: 'The Book — notes your phone keeps about the people you care about.',
  },
  {
    src: '/phone-os/PTC4.png',
    caption: 'Ask — a single prompt that pulls from what the phone already knows about your day.',
  },
  {
    src: '/phone-os/PTC2.png',
    caption: 'Discover — a feed that admits it is a feed, and lets you reshape it.',
  },
  {
    src: '/phone-os/PTC2b.png',
    caption: 'Scroll Settings — turn the friction on, pick the experiment you want today.',
  },
];

const scrollLabSlides = [
  {
    src: '/experiments/scroll-lab-tweet-padding.png',
    caption: 'Tweet Padding — extra whitespace between posts slows the scroll cadence.',
  },
  {
    src: '/experiments/scroll-lab-greyscale.png',
    caption: 'Greyscale — desaturating the feed strips out color-driven engagement cues.',
  },
  {
    src: '/experiments/scroll-lab-blur.png',
    caption: 'Blur — content stays readable on focus but resists peripheral grazing.',
  },
  {
    src: '/experiments/scroll-lab-break-cards.png',
    caption: 'Break Cards — tweets fragment into broken shapes, making the feed harder to passively absorb.',
  },
  {
    src: '/experiments/scroll-lab-font-cycling.png',
    caption: 'Font Cycling — each post renders in a different typeface, breaking the visual rhythm.',
  },
  {
    type: 'video',
    src: '/experiments/scroll-lab-features.mov',
    poster: '/experiments/scroll-lab-tweet-padding.png',
    caption: 'See it in motion — a short walk-through of every mode in The Scroll Lab.',
  },
];
---

<BaseLayout
  theme="experiments"
  activeSlug="experiments"
  title="Experiments — Phone That Cares About You"
>
  <article class="experiments-page">
    <header class="intro">
      <h1>Experiments</h1>
      <p class="lede" data-nav-fade-trigger>
        Prototypes for changing how content reaches you. Small interventions
        that test the question: what would it feel like if the feed pushed
        back, even a little?
      </p>
    </header>

    <section class="experiment" aria-labelledby="scroll-lab">
      <header class="experiment-head">
        <p class="experiment-kicker">Experiment 01</p>
        <h2 id="scroll-lab">The Scroll Lab</h2>
        <p class="experiment-tagline">
          A Chrome extension that applies live visual transformations to your
          social feed.
        </p>
      </header>

      <Carousel client:load slides={scrollLabSlides} />

      <div class="experiment-body">
        <p>
          The Scroll Lab is a small Chrome extension that lets you toggle
          experimental visual treatments on top of X / Twitter in real time.
          Padding, fragmenting, blurring, desaturating, distorting — each mode
          is a deliberate piece of friction, dropped between you and the feed
          to see what changes.
        </p>
        <p>
          The point isn't to make the feed unusable. It's to notice what your
          attention actually does when the usual visual rhythm is interrupted.
          Most of these tweaks took ten minutes to write. A few of them
          changed how I scroll for the rest of the day.
        </p>
        <p>
          It also tracks how long you've been on the site and how many posts
          you've passed — quietly, in the corner of the panel — so you can
          watch the experiment of the experiment.
        </p>
      </div>

      <div class="experiment-cta">
        <a class="download-button" href="/experiments/scroll-lab.zip" download>
          Download The Scroll Lab <span class="arrow">↓</span>
        </a>
        <p class="install-note">
          Unzip, then in Chrome go to <code>chrome://extensions</code>, enable
          <em>Developer mode</em>, click <em>Load unpacked</em>, and select the
          unzipped folder.
        </p>
      </div>
    </section>

    <section class="experiment" aria-labelledby="phone-os">
      <header class="experiment-head">
        <p class="experiment-kicker">Experiment 02</p>
        <h2 id="phone-os">A Phone That Cares</h2>
        <p class="experiment-tagline">
          A clickable mock-up of a phone OS that nudges toward presence,
          reflection, and the people you actually care about.
        </p>
      </header>

      <Carousel client:load slides={phoneOsSlides} />

      <div class="experiment-body">
        <p>
          This is a design prototype — a walk-through of what a phone could
          feel like if its defaults were tuned for attention, relationships,
          and a little bit of friction. Not a real OS. A sketch made clickable,
          so the ideas can be argued with instead of just described.
        </p>
        <p>
          The home screen stays boring on purpose. The Connect page collapses
          every messaging platform into one human list. Every person has a
          Book — a small repository of notes the phone keeps for you: how you
          met, what they like, who matters to them. Before you text someone,
          you can Think Out Loud first, privately, with just the phone.
        </p>
        <p>
          The Ask screen starts from what the phone already knows about your
          day. The Discover feed tells you it's a feed, and lets you choose
          the friction you want — grayscale, padding, blur, whatever pulls
          you out of the scroll. The whole thing is a single question made
          tangible: what would it feel like if the device on your nightstand
          were on your side?
        </p>
      </div>

      <div class="experiment-cta">
        <a class="download-button" href="/os-mock/" target="_blank" rel="noopener">
          Open the live mock-up <span class="arrow">→</span>
        </a>
        <p class="install-note">
          Opens in a new tab. Click around — almost every screen is wired up.
          Designed for a phone frame; works best on desktop.
        </p>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .experiments-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .intro {
    margin-bottom: 4rem;
  }

  .intro h1 {
    margin-bottom: 1.25rem;
  }


  .experiment {
    border-top: 1px solid var(--border-subtle);
    padding-top: 2.25rem;
  }

  .experiment-head {
    margin-bottom: 2rem;
  }

  .experiment-kicker {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .experiment h2 {
    font-size: clamp(1.5rem, 3.4vw, 2.1rem);
    margin-bottom: 0.6rem;
    line-height: 1.2;
  }

  .experiment-tagline {
    font-size: 1rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .experiment-body {
    margin-top: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .experiment-body p {
    line-height: 1.7;
  }

  .experiment-cta {
    margin-top: 2.5rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    background: rgba(43, 43, 34, 0.025);
  }

  .download-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--accent);
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: 2px;
    transition: border-color 150ms ease, gap 150ms ease;
  }

  .download-button:hover {
    border-color: var(--accent);
  }

  .download-button:hover .arrow {
    transform: translateY(2px);
  }

  .arrow {
    display: inline-block;
    transition: transform 200ms ease;
  }

  .install-note {
    margin-top: 0.9rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .install-note code {
    font-family: 'SF Mono', Menlo, Consolas, monospace;
    font-size: 0.8rem;
    background: rgba(43, 43, 34, 0.06);
    padding: 1px 6px;
    border-radius: 3px;
  }

  .install-note em {
    font-style: normal;
    color: var(--text-primary);
    font-weight: 500;
  }
</style>
