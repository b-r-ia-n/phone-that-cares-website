---
import { tabs } from '../config/tabs';

interface Props {
  activeSlug: string;
}

const { activeSlug } = Astro.props;

function hrefFor(slug: string) {
  return slug === 'welcome' ? '/' : `/${slug}`;
}
---

<nav class="navbar" id="navbar" aria-label="Primary">
  <ul class="navbar-list">
    {tabs.map(tab => (
      <li>
        <a
          href={hrefFor(tab.slug)}
          class:list={['navbar-link', { active: tab.slug === activeSlug }]}
          aria-current={tab.slug === activeSlug ? 'page' : undefined}
        >
          {tab.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
    padding: 24px 28px;
    height: 100vh;
    display: flex;
    align-items: flex-start;
    padding-top: clamp(2rem, 5vw, 4rem);
    transition:
      background-color 350ms ease,
      border-color 350ms ease;
  }

  .navbar-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar-link {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--accent-muted);
    border-bottom: none;
    letter-spacing: 0.01em;
    transition: color 150ms ease, opacity 150ms ease;
    white-space: nowrap;
  }

  .navbar-link:hover {
    color: var(--accent);
    opacity: 0.8;
    border-bottom: none;
  }

  .navbar-link.active {
    color: var(--accent);
    font-weight: 500;
  }

  @media (max-width: 960px) {
    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: auto;
      padding: 12px 24px;
      padding-top: 12px;
      background-color: var(--nav-bg);
      border-bottom: 0.5px solid var(--border-subtle);
      display: flex;
      align-items: center;
    }

    .navbar-list {
      flex-direction: row;
      gap: 16px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      white-space: nowrap;
    }

    .navbar-list::-webkit-scrollbar {
      display: none;
    }
  }

  @media (max-width: 420px) {
    .navbar-list {
      gap: 12px;
    }
    .navbar-link {
      font-size: 12px;
    }
  }
</style>
