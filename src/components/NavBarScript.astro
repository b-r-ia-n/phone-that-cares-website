<script>
  // Scroll-direction nav fade.
  // Scrolling down: nav fades out. Any scroll up: nav fades back in.

  const FADE_DISTANCE = 80;
  const RETRACT_PX = 10;

  let scrollHandler: ((e?: Event) => void) | null = null;
  let resizeHandler: (() => void) | null = null;

  function setupNavFade() {
    const nav = document.getElementById('navbar') as HTMLElement | null;
    if (!nav) return;

    if (scrollHandler) window.removeEventListener('scroll', scrollHandler);
    if (resizeHandler) window.removeEventListener('resize', resizeHandler);

    let lastScrollY = window.scrollY;
    let targetOpacity = 1;
    let currentOpacity = 1;
    let rafId: number | null = null;

    function isMobile() {
      return window.innerWidth <= 960;
    }

    function animate() {
      // Ease toward target
      currentOpacity += (targetOpacity - currentOpacity) * 0.25;
      if (Math.abs(currentOpacity - targetOpacity) < 0.01) {
        currentOpacity = targetOpacity;
      }

      const progress = 1 - currentOpacity;
      const ty = -RETRACT_PX * progress;
      nav!.style.opacity = String(currentOpacity);
      nav!.style.transform = `translateY(${ty}px)`;
      nav!.style.pointerEvents = currentOpacity < 0.05 ? 'none' : '';

      if (currentOpacity !== targetOpacity) {
        rafId = requestAnimationFrame(animate);
      } else {
        rafId = null;
      }
    }

    function startAnimation() {
      if (rafId === null) {
        rafId = requestAnimationFrame(animate);
      }
    }

    function onScroll() {
      if (isMobile()) {
        nav!.style.opacity = '1';
        nav!.style.transform = '';
        nav!.style.pointerEvents = '';
        lastScrollY = window.scrollY;
        return;
      }

      const currentScrollY = window.scrollY;

      if (currentScrollY <= 10) {
        // At the top — always visible
        targetOpacity = 1;
      } else if (currentScrollY < lastScrollY) {
        // Scrolling up — show
        targetOpacity = 1;
      } else if (currentScrollY > lastScrollY) {
        // Scrolling down — hide
        targetOpacity = 0;
      }

      lastScrollY = currentScrollY;
      startAnimation();
    }

    scrollHandler = onScroll;
    resizeHandler = onScroll;

    window.addEventListener('scroll', scrollHandler, { passive: true });
    window.addEventListener('resize', resizeHandler);
  }

  setupNavFade();
  document.addEventListener('astro:page-load', setupNavFade);
</script>
